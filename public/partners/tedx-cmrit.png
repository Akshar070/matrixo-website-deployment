    max-width: 160px;
    position: relative;
    top: -25px;
}
.elementor-11 .elementor-element.elementor-element-c1621e8 > .elementor-widget-container {
    padding: 0;
    background: transparent;
    position: relative;
}
.elementor-11 .elementor-element.elementor-element-c1621e8 > .elementor-widget-container:before {
    content: '';
    width: 200px;
    height: 114px;
    background: #fff;
    position: absolute;
    left: 52px;
}
.sticky_header .elementor-element.elementor-element-c1621e8 img {
    top: 0;
}
.sticky_header .elementor-widget-wrap {
    align-content: center;
}
/* end */
.newsletter{
    display:flex;
    flex-wrap:wrap;
    justify-content:left;
}
.newsletter > ul{
    width:33%;
	  margin: 10px 0;
}
.newsletter > ul li {
    margin: 10px 0;
}
.faculty-list li {
    list-style: disc;
    color: red;
    width: 32%;
    margin-right:10px !important;
    padding: 4px 0 !important;
}
ul.faculty-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: left !important;
    margin-left:-45px;
}
.faculty-list li a{
    color:#000000;
}
.faculty-list li a span{
    font-size: 15px;
}
.faculty-list .fa-circle{
    font-size:5px !important;
    color:#036059;
}
@media screen and (max-width:1024px){
	.elementor-11 .elementor-element.elementor-element-c1621e8 img {
    top: 5px;
    left: 55px;
    max-width: 150px !important;
    height: auto;
}
}
@media screen and (max-width:767px){
	#sticky-right-button {
    display: block !important;
    top: 54%;
    right: -120px;
}
    .faculty-list li{
       width:100%;
    }
	.elementor-11 .elementor-element.elementor-element-c1621e8 > .elementor-widget-container:before {
		background:transparent;
	}
	.elementor-11 .elementor-element.elementor-element-bebb2f8 div.elementor-menu-toggle {
    position: relative;
    transform: translateX(-20px);
}
	.elementor-11 .elementor-element.elementor-element-c1621e8 img {
    max-height: 80px;
}
	
	    #Mobile-sticky .elementor-widget .elementor-icon-list-icon {
        background: #2981ba;
        font-size: 27px !important;
        padding-right: 9px;
    }
	
	.elementor-icon-list-items .elementor-icon-list-item .elementor-icon-list-text {
    background: #2981ba;
}
	
	.yearly_admission .elementor-widget-container {
    background: #2981ba;
}
	
	.elementor-widget-icon-list .elementor-icon-list-icon svg {
    fill: #f6f6f6;
}
}
.elementor-location-header{
	margin-top: -24px;
}		</style>
