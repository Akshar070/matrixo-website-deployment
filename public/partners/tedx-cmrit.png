<script>
	//use window.scrollY
	var scrollpos = window.scrollY;
	var header = document.getElementById("new_header");

	function add_class_on_scroll() {
	    header.classList.add("sticky_header");
	}

	function remove_class_on_scroll() {
	    header.classList.remove("sticky_header");
	}

	window.addEventListener('scroll', function(){ 
	    //Here you forgot to update the value
	    scrollpos = window.scrollY;

	    if(scrollpos > 10){
	        add_class_on_scroll();
	    }
	    else {
	        remove_class_on_scroll();
	    }
	});


	//use window.scrollY
	var scrollpos2 = window.scrollY;
	var header2 = document.getElementById("Menu-sec");

	function add_class_on_scroll2() {
	    header2.classList.add("sticky_header");
	}

	function remove_class_on_scroll2() {
	    header2.classList.remove("sticky_header");
	}

	window.addEventListener('scroll', function(){ 
	    //Here you forgot to update the value
	    scrollpos2 = window.scrollY;

	    if(scrollpos2 > 10){
	        add_class_on_scroll2();
	    }
	    else {
	        remove_class_on_scroll2();
	    }
	});
</script>

<style>
	.elementor-element-ba9e405.sticky_header{
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		background-color: #fff;
		z-index: 9999;
		padding-top: 10px!important;
		padding-bottom: 10px!important;
	}
	#Menu-sec.sticky_header {
